# HTTP Status Code 300
#: configuration/http-statuscodes.tsv
msgid "Multiple Choices"
msgstr "Çoklu seçimler"

# HTTP Status Code 301
#: configuration/http-statuscodes.tsv
msgid "Moved Permanently"
msgstr "Kalıcı Olarak Taşındı"

# HTTP Status Code 302
#: configuration/http-statuscodes.tsv
msgid "Found"
msgstr "Bulundu"

# HTTP Status Code 303
#: configuration/http-statuscodes.tsv
msgid "See Other"
msgstr "Diğerini gör"

# HTTP Status Code 304
#: configuration/http-statuscodes.tsv
msgid "Not Modified"
msgstr "Değiştirilmedi"

# HTTP Status Code 305
#: configuration/http-statuscodes.tsv
msgid "Use Proxy"
msgstr "Porxy Kullan"

# HTTP Status Code 307
#: configuration/http-statuscodes.tsv
msgid "Temporary Redirect"
msgstr "Geçici Yönlendirme"

# HTTP Status Code 400
#: configuration/http-statuscodes.tsv
msgid "Bad Request"
msgstr "Geçersiz istek"

# HTTP Status Code 400
#: configuration/http-statuscodes.tsv
msgid ""
"Your browser (or proxy) sent a request that this server could not understand."
msgstr "Tarayıcınız (veya proxy) bu sunucunun anlayamadığı bir istek gönderdi."

# HTTP Status Code 401
#: configuration/http-statuscodes.tsv
msgid "Unauthorized"
msgstr "Yetkisiz"

# HTTP Status Code 401
#: configuration/http-statuscodes.tsv
msgid ""
"This server could not verify that you are authorized to access this URL. You "
"either supplied the wrong credentials (e.g., bad password), or your browser "
"doesn't understand how to supply the credentials required."
msgstr ""
"Bu sunucu, bu URL'ye erişim yetkiniz olduğunu doğrulayamadı. Ya yanlış "
"kimlik bilgilerini verdiniz (örneğin, hatalı parola) ya da tarayıcınız "
"gerekli kimlik bilgilerini nasıl vereceğinizi anlamıyor."

# HTTP Status Code 402
#: configuration/http-statuscodes.tsv
msgid "Payment Required"
msgstr "Ödeme gerekli"

# HTTP Status Code 403
#: configuration/http-statuscodes.tsv
msgid "Forbidden"
msgstr "Yasak"

# HTTP Status Code 403
#: configuration/http-statuscodes.tsv
msgid ""
"You don't have permission to access the requested object. It is either read-"
"protected or not readable by the server."
msgstr ""
"İstenen nesneye erişim izniniz yok. Nesne ya okuma korumalı ya da sunucu "
"tarafından okunamıyor."

# HTTP Status Code 404
#: configuration/http-statuscodes.tsv
msgid "Not Found"
msgstr "Bulunamadı"

# HTTP Status Code 404
#: configuration/http-statuscodes.tsv
msgid "The requested URL was not found on this server."
msgstr "İstenen URL bu sunucuda bulunamadı."

# HTTP Status Code 405
#: configuration/http-statuscodes.tsv
msgid "Method Not Allowed"
msgstr "izin verilmeyen yöntem"

# HTTP Status Code 405
#: configuration/http-statuscodes.tsv
msgid "The %s-method is not allowed for the requested URL."
msgstr "İstenen URL için %s-metoduna izin verilmiyor."

# HTTP Status Code 406
#: configuration/http-statuscodes.tsv
msgid "Not Acceptable"
msgstr "Kabul Edilemez"

# HTTP Status Code 407
#: configuration/http-statuscodes.tsv
msgid "Proxy Authentication Required"
msgstr "Proxy Kimlik Doğrulaması Gerekli"

# HTTP Status Code 409
#: configuration/http-statuscodes.tsv
msgid "Conflict"
msgstr "Çakışma"

# HTTP Status Code 410
#: configuration/http-statuscodes.tsv
msgid "Gone"
msgstr "Gitti"

# HTTP Status Code 410
#: configuration/http-statuscodes.tsv
msgid ""
"The requested URL is no longer available on this server and there is no "
"forwarding address."
msgstr "İstenen URL artık bu sunucuda mevcut değil ve yönlendirme adresi yok."

# HTTP Status Code 411
#: configuration/http-statuscodes.tsv
msgid "Length Required"
msgstr "Uzunluk Gerekli"

# HTTP Status Code 411
#: configuration/http-statuscodes.tsv
msgid ""
"A request with the %s-method requires a valid <code>Content-Length</code> "
"header."
msgstr ""
"%s-metodu ile yapılan bir istek geçerli bir <code>Content-Length</code> "
"başlığı gerektirir."

# HTTP Status Code 412
#: configuration/http-statuscodes.tsv
msgid "Precondition Failed"
msgstr "Önkoşul Başarısız Oldu"

# HTTP Status Code 412
#: configuration/http-statuscodes.tsv
msgid "The precondition on the request for the URL failed positive evaluation."
msgstr "URL isteğindeki ön koşul olumlu değerlendirmede başarısız oldu."

# HTTP Status Code 413
#: configuration/http-statuscodes.tsv
msgid "Request Entity Too Large"
msgstr "Girilen veri çok büyük"

# HTTP Status Code 413
#: configuration/http-statuscodes.tsv
msgid ""
"The %s-method does not allow the data transmitted, or the data volume "
"exceeds the capacity limit."
msgstr ""
"0]-yöntemi iletilen verilere izin vermiyor veya veri hacmi kapasite sınırını "
"aşıyor."

# HTTP Status Code 414
#: configuration/http-statuscodes.tsv
msgid "URI Too Long"
msgstr "Adres çok uzun"

# HTTP Status Code 414
#: configuration/http-statuscodes.tsv
msgid ""
"The length of the requested URL exceeds the capacity limit for this server. "
"The request cannot be processed."
msgstr ""
"İstenen URL'nin uzunluğu bu sunucu için kapasite sınırını aşıyor. İstek "
"işlenemiyor."

# HTTP Status Code 415
#: configuration/http-statuscodes.tsv
msgid "Unsupported Media Type"
msgstr "Desteklenmeyen Medya Türü"

# HTTP Status Code 415
#: configuration/http-statuscodes.tsv
msgid "The server does not support the media type transmitted in the request."
msgstr "Sunucu, istekte iletilen ortam türünü desteklemiyor."

# HTTP Status Code 416
#: configuration/http-statuscodes.tsv
msgid "Requested Range Not Satisfiable"
msgstr "İstenen Aralık Karşılaşılamıyor"

# HTTP Status Code 417
#: configuration/http-statuscodes.tsv
msgid "Expectation Failed"
msgstr "Beklenti karşılanamadı"

# HTTP Status Code 417
#: configuration/http-statuscodes.tsv
msgid "Too Many Requests"
msgstr "Çok fazla İstek var"

# HTTP Status Code 500
#: configuration/http-statuscodes.tsv
msgid "Internal Server Error"
msgstr "İç Sunucu Hatası"

# HTTP Status Code 500
#: configuration/http-statuscodes.tsv
msgid ""
"The server encountered an internal error and was unable to complete your "
"request."
msgstr "Sunucu dahili bir hatayla karşılaştı ve isteğinizi tamamlayamadı."

# HTTP Status Code 500
#: configuration/http-statuscodes.tsv
msgid "Unsupported server protocol (%s)"
msgstr "Desteklenmeyen sunucu protokolü (%s)"

# HTTP Status Code 501
#: configuration/http-statuscodes.tsv
msgid "Not Implemented"
msgstr "Uygulanmadı"

# HTTP Status Code 501
#: configuration/http-statuscodes.tsv
msgid "The server does not support the action requested by the browser (%s)."
msgstr "Sunucu, tarayıcı tarafından talep edilen eylemi desteklemiyor (%s)."

# HTTP Status Code 502
#: configuration/http-statuscodes.tsv
msgid "Bad Gateway"
msgstr "Ağ geçidi sorunu"

# HTTP Status Code 502
#: configuration/http-statuscodes.tsv
msgid "The proxy server received an invalid response from an upstream server."
msgstr "Proxy sunucu bir yukarı akış sunucusundan geçersiz bir yanıt aldı."

# HTTP Status Code 503
#: configuration/http-statuscodes.tsv
msgid "Service Unavailable"
msgstr "Hizmet kullanılamıyor"

# HTTP Status Code 503
#: configuration/http-statuscodes.tsv
msgid ""
"The server is temporarily unable to service your request due to maintenance "
"downtime or capacity problems. Please try again later."
msgstr ""
"Sunucu, bakım kesintisi veya kapasite sorunları nedeniyle isteğinize geçici "
"olarak hizmet veremiyor. Lütfen daha sonra tekrar deneyin."

# HTTP Status Code 504
#: configuration/http-statuscodes.tsv
msgid "Gateway Timeout"
msgstr "Ağ Geçidi Zaman Aşımı"

# HTTP Status Code 505
#: configuration/http-statuscodes.tsv
msgid "HTTP Version Not Supported"
msgstr "HTTP Sürümü Desteklenmiyor"

#: zzbrick_request/login.inc.php
