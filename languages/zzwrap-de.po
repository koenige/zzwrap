# HTTP Status Code 300
#: configuration/http-statuscodes.tsv
msgid "Multiple Choices"
msgstr "Mehrfachauswahl"

# HTTP Status Code 301
#: configuration/http-statuscodes.tsv
msgid "Moved Permanently"
msgstr "Dauerhaft verschoben"

# HTTP Status Code 302
#: configuration/http-statuscodes.tsv
msgid "Found"
msgstr "Umleitung (unbestimmt)"

# HTTP Status Code 303
#: configuration/http-statuscodes.tsv
msgid "See Other"
msgstr "Umleitung"

# HTTP Status Code 304
#: configuration/http-statuscodes.tsv
msgid "Not Modified"
msgstr "Keine Veränderung"

# HTTP Status Code 305
#: configuration/http-statuscodes.tsv
msgid "Use Proxy"
msgstr "Proxy benutzen"

# HTTP Status Code 307
#: configuration/http-statuscodes.tsv
msgid "Temporary Redirect"
msgstr "Vorübergehende Umleitung"

# HTTP Status Code 400
#: configuration/http-statuscodes.tsv
msgid "Bad Request"
msgstr "Fehlerhafte Anfrage"

# HTTP Status Code 400
#: configuration/http-statuscodes.tsv
msgid ""
"Your browser (or proxy) sent a request that this server could not understand."
msgstr ""
"Ihr Browser (oder Proxy) hat eine ungültige Anfrage gesendet, die vom Server "
"nicht beantwortet werden kann."

# HTTP Status Code 401
#: configuration/http-statuscodes.tsv
msgid "Unauthorized"
msgstr "Anmeldung fehlgeschlagen"

# HTTP Status Code 401
#: configuration/http-statuscodes.tsv
msgid ""
"This server could not verify that you are authorized to access this URL. You "
"either supplied the wrong credentials (e.g., bad password), or your browser "
"doesn't understand how to supply the credentials required."
msgstr ""
"Der Server konnte nicht prüfen, ob Sie autorisiert sind, auf diese URL "
"zuzugreifen. Entweder wurden falsche Daten (z. B. ein falsches Passwort) "
"angegeben oder Ihr Browser versteht nicht, wie die geforderten Daten zu "
"übermitteln sind."

# HTTP Status Code 402
#: configuration/http-statuscodes.tsv
msgid "Payment Required"
msgstr "Bezahlung erforderlich"

# HTTP Status Code 403
#: configuration/http-statuscodes.tsv
msgid "Forbidden"
msgstr "Kein Zugriff"

# HTTP Status Code 403
#: configuration/http-statuscodes.tsv
msgid ""
"You don't have permission to access the requested object. It is either read-"
"protected or not readable by the server."
msgstr ""
"Der Zugriff auf den angeforderten Inhalt ist nicht möglich. Entweder kann er "
"vom Server nicht gelesen werden oder er ist zugriffsgeschützt."

# HTTP Status Code 404
#: configuration/http-statuscodes.tsv
msgid "Not Found"
msgstr "Inhalt nicht gefunden"

# HTTP Status Code 404
#: configuration/http-statuscodes.tsv
msgid "The requested URL was not found on this server."
msgstr "Der von Ihnen gewünschte Inhalt konnte nicht gefunden werden."

# HTTP Status Code 405
#: configuration/http-statuscodes.tsv
msgid "Method Not Allowed"
msgstr "Methode nicht erlaubt"

# HTTP Status Code 405
#: configuration/http-statuscodes.tsv
msgid "The %s-method is not allowed for the requested URL."
msgstr "Die %s-Methode ist für die angeforderte URL nicht erlaubt."

# HTTP Status Code 406
#: configuration/http-statuscodes.tsv
msgid "Not Acceptable"
msgstr "Nicht verarbeitbar"

# HTTP Status Code 407
#: configuration/http-statuscodes.tsv
msgid "Proxy Authentication Required"
msgstr "Proxyanmeldung erforderlich"

# HTTP Status Code 409
#: configuration/http-statuscodes.tsv
msgid "Conflict"
msgstr "Konflikt"

# HTTP Status Code 410
#: configuration/http-statuscodes.tsv
msgid "Gone"
msgstr "Inhalt nicht mehr verfügbar"

# HTTP Status Code 410
#: configuration/http-statuscodes.tsv
msgid ""
"The requested URL is no longer available on this server and there is no "
"forwarding address."
msgstr ""
"Der angeforderte Inhalt existiert auf dem Server nicht mehr und wurde "
"dauerhaft entfernt. Eine Weiterleitungsadresse ist nicht verfügbar."

# HTTP Status Code 411
#: configuration/http-statuscodes.tsv
msgid "Length Required"
msgstr "Content-Length-Angabe fehlerhaft"

# HTTP Status Code 411
#: configuration/http-statuscodes.tsv
msgid ""
"A request with the %s-method requires a valid <code>Content-Length</code> "
"header."
msgstr ""
"Die Anfrage kann nicht beantwortet werden. Bei Verwendung der %s-Methode muß "
"ein korrekter <code>Content-Length</code>-Header angegeben werden."

# HTTP Status Code 412
#: configuration/http-statuscodes.tsv
msgid "Precondition Failed"
msgstr "Vorbedingung verfehlt"

# HTTP Status Code 412
#: configuration/http-statuscodes.tsv
msgid "The precondition on the request for the URL failed positive evaluation."
msgstr ""
"Die für den Abruf der angeforderten URL notwendige Vorbedingung wurde nicht "
"erfüllt."

# HTTP Status Code 413
#: configuration/http-statuscodes.tsv
msgid "Request Entity Too Large"
msgstr "Übergebene Daten zu groß"

# HTTP Status Code 413
#: configuration/http-statuscodes.tsv
msgid ""
"The %s-method does not allow the data transmitted, or the data volume "
"exceeds the capacity limit."
msgstr ""
"Die bei der Anfrage übermittelten Daten sind für die %s-Methode nicht "
"erlaubt oder die Datenmenge hat das Maximum überschritten."

# HTTP Status Code 414
#: configuration/http-statuscodes.tsv
msgid "URI Too Long"
msgstr "URI zu lang"

# HTTP Status Code 414
#: configuration/http-statuscodes.tsv
msgid ""
"The length of the requested URL exceeds the capacity limit for this server. "
"The request cannot be processed."
msgstr ""
"Die bei der Anfrage übermittelte URI überschreitet die maximale Länge. Die "
"Anfrage kann nicht ausgeführt werden."

# HTTP Status Code 415
#: configuration/http-statuscodes.tsv
msgid "Unsupported Media Type"
msgstr "Nicht unterstütztes Format"

# HTTP Status Code 415
#: configuration/http-statuscodes.tsv
msgid "The server does not support the media type transmitted in the request."
msgstr ""
"Das bei der Anfrage übermittelte Format (Media Type) wird vom Server nicht "
"unterstützt."

# HTTP Status Code 416
#: configuration/http-statuscodes.tsv
msgid "Requested Range Not Satisfiable"
msgstr "Abgefragtes Intervall (<code>range</code>) nicht erfüllbar"

# HTTP Status Code 417
#: configuration/http-statuscodes.tsv
msgid "Expectation Failed"
msgstr "Erwartung (<code>Expect</code>) fehlgeschlagen"

# HTTP Status Code 417
#: configuration/http-statuscodes.tsv
msgid "Too Many Requests"
msgstr "Zu viele Anfragen"

# HTTP Status Code 500
#: configuration/http-statuscodes.tsv
msgid "Internal Server Error"
msgstr "Serverfehler"

# HTTP Status Code 500
#: configuration/http-statuscodes.tsv
msgid ""
"The server encountered an internal error and was unable to complete your "
"request."
msgstr ""
"Die Anfrage kann nicht beantwortet werden, da im Server ein interner Fehler "
"aufgetreten ist."

# HTTP Status Code 500
#: configuration/http-statuscodes.tsv
msgid "Unsupported server protocol (%s)"
msgstr "Server-Protokoll wird nicht unterstützt (%s)"

# HTTP Status Code 501
#: configuration/http-statuscodes.tsv
msgid "Not Implemented"
msgstr "Abfrage nicht unterstützt"

# HTTP Status Code 501
#: configuration/http-statuscodes.tsv
msgid "The server does not support the action requested by the browser (%s)."
msgstr ""
"Die vom Browser angeforderte Aktion wird vom Server nicht unterstützt (%s)."

# HTTP Status Code 502
#: configuration/http-statuscodes.tsv
msgid "Bad Gateway"
msgstr "Fehlerhaftes Gateway"

# HTTP Status Code 502
#: configuration/http-statuscodes.tsv
msgid "The proxy server received an invalid response from an upstream server."
msgstr ""
"Der Proxy-Server erhielt eine fehlerhafte Antwort eines übergeordneten "
"Servers oder Proxies."

# HTTP Status Code 503
#: configuration/http-statuscodes.tsv
msgid "Service Unavailable"
msgstr "Dienst steht nicht zur Verfügung"

# HTTP Status Code 503
#: configuration/http-statuscodes.tsv
msgid ""
"The server is temporarily unable to service your request due to maintenance "
"downtime or capacity problems. Please try again later."
msgstr ""
"Der Server kann zur Zeit Ihre Anfrage nicht bearbeiten. Grund kann eine "
"Überlastung oder eine Wartung des Servers sein. Bitte versuchen Sie es "
"später noch einmal."

# HTTP Status Code 504
#: configuration/http-statuscodes.tsv
msgid "Gateway Timeout"
msgstr "Zeitlimit am Netzübergang (<code>gateway</code>) überschritten"

# HTTP Status Code 505
#: configuration/http-statuscodes.tsv
msgid "HTTP Version Not Supported"
msgstr "HTTP-Version nicht unterstützt"

